---
import { guides } from "../data/guides";

const { current } = Astro.props;

const normalizeHref = (href = "") => href.replace(/\/$/, "");

const filteredGuides = guides
  .filter((guide) => normalizeHref(guide.href) !== normalizeHref(current))
  .slice(0, 4);
---

<section class="card">
  <div class="section-heading">
    <div>
      <p class="section-eyebrow">Helpful reading</p>
      <h2>Related Guides</h2>
    </div>
    <p class="muted">Plain-English explanations for the math behind the result.</p>
  </div>

  <div class="related-grid">
    {filteredGuides.map((guide) => (
      <a href={guide.href} class="resource-link">
        <strong>{guide.title}</strong>
        <span>Read examples, definitions, and tips to understand the numbers better.</span>
      </a>
    ))}
  </div>
</section>
