---
import { tools } from "../data/tools";

const { current = null } = Astro.props;

const filteredTools = current
  ? tools.filter((tool) => tool.href !== current)
  : tools;
---

<section class="card" style="margin-top: 1.25rem;">
  <h2>Related Tools</h2>

  <p>
    {filteredTools.map((tool, index) => (
      <>
        <a href={tool.href}>{tool.title}</a>
        {index < filteredTools.length - 1 ? " | " : ""}
      </>
    ))}
  </p>
</section>