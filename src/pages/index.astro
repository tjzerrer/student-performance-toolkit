---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { tools } from "../data/tools";
import { guides } from "../data/guides";
---

<BaseLayout
  title={`${site.name} | Grade, GPA, Final Exam & Weighted Grade Calculators`}
  description={site.description}
>
  <section class="hero">
    <h1>{site.name}</h1>
    <p>
      Free, simple tools and guides for students who want quick answers about
      grades, finals, weighted averages, GPA, and what they need to reach their
      goals.
    </p>
  </section>

  <div class="card">
    <h2>Tools</h2>
    <ul>
      {tools.map((tool) => (
        <li><a href={tool.href}>{tool.title}</a></li>
      ))}
    </ul>
  </div>

  <div class="card">
    <h2>Guides</h2>
    <ul>
      {guides.map((guide) => (
        <li><a href={guide.href}>{guide.title}</a></li>
      ))}
    </ul>
  </div>

  <div class="card">
    <h2>About These Tools</h2>
    <p>
      This site helps students calculate grades, understand weighted averages,
      estimate final exam outcomes, and track GPA. Each tool is built to be
      simple, fast, and useful without requiring signup or extra steps.
    </p>

    <p class="muted">
      More tools coming next: cumulative GPA calculator, semester GPA tracker,
      weighted GPA calculator, and additional grade strategy guides.
    </p>
  </div>
</BaseLayout>