---
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import ResourceLinks from "../components/ResourceLinks.astro";
import { site } from "../data/site";
import { tools } from "../data/tools";
import { guides } from "../data/guides";
import { guideResources, homepageFeaturedTools, homepagePopularQuestions } from "../data/content";

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${site.name} Home`,
  url: site.url,
  description: site.description,
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: site.url,
  },
};
---

<BaseLayout
  title="Grade Toolkit | Grade, Final Exam, and GPA Calculators"
  description="Calculate your current grade, final exam score needed, weighted grade, GPA, and GPA goals with simple student-friendly tools."
  socialImage="/social/home.png"
  socialImageAlt="Grade Toolkit social preview card"
>
  <Fragment slot="head">
    <JsonLd data={webSiteSchema} />
    <JsonLd data={collectionPageSchema} />
  </Fragment>

  <section class="hero-card homepage-hero">
    <div class="hero">
      <p class="hero-eyebrow">Plan smarter, stress less</p>
      <h1>{site.name}</h1>
      <p class="hero-copy">
        Plan your grades, finals, and GPA with simple student-friendly calculators.
        See where you stand now, what score you need next, and how your courses
        affect your GPA.
      </p>

      <div class="hero-actions">
        <a class="btn-primary" href="/grade-calculator/">Open grade calculator</a>
        <a class="btn-secondary" href="/final-exam-calculator/">Check final exam score</a>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="section-eyebrow">Built for the moments that matter</p>
      <h2>When students usually need help fast</h2>
      <ul>
        <li>Checking whether one bad quiz changed the class average much.</li>
        <li>Figuring out the exact final exam score needed to hit a target grade.</li>
        <li>Comparing weighted classes, honors boosts, and GPA scenarios.</li>
      </ul>
      <div class="pill-row" aria-label="Popular student goals">
        <a class="pill" href="/grade-calculator/">Know where you stand</a>
        <a class="pill" href="/what-grade-do-i-need-calculator/">Set a grade target</a>
        <a class="pill" href="/gpa-calculator/">Track GPA clearly</a>
      </div>
    </aside>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Start here</p>
        <h2>A Simple Grade Planning Workflow</h2>
      </div>
      <p class="muted">Move from current grade to next action.</p>
    </div>

    <div class="workflow-grid">
      <a class="workflow-card" href="/grade-calculator/">
        <span class="workflow-step">1</span>
        <h3>Calculate Your Current Grade</h3>
        <p>Enter points, assignments, or categories to see where you stand right now.</p>
      </a>

      <a class="workflow-card" href="/what-grade-do-i-need-calculator/">
        <span class="workflow-step">2</span>
        <h3>Set a Target Grade</h3>
        <p>Find out what score you need on upcoming work to reach your goal.</p>
      </a>

      <a class="workflow-card" href="/final-exam-calculator/">
        <span class="workflow-step">3</span>
        <h3>Check Your Final Exam Score</h3>
        <p>Calculate what you need on the final to finish with your target class grade.</p>
      </a>

      <a class="workflow-card" href="/gpa-calculator/">
        <span class="workflow-step">4</span>
        <h3>Track Your GPA</h3>
        <p>Calculate GPA by course, credit, semester, and grade format.</p>
      </a>
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Calculator collection</p>
        <h2>Tools students use the most</h2>
      </div>
      <p class="muted">Start with the one that answers today's question.</p>
    </div>

    <div class="resource-grid">
      {tools.map((tool) => (
        <a class="resource-link" href={tool.href}>
          <strong>{tool.title}</strong>
          <span>{tool.description}</span>
        </a>
      ))}
    </div>
  </section>

  <ResourceLinks
    eyebrow="Popular questions"
    title="Popular Grade Questions"
    intro="Quick answers to the grade questions students, parents, and counselors ask most often."
    items={homepagePopularQuestions}
  />

  <section class="card">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Study guides</p>
        <h2>Short reads that explain the math</h2>
      </div>
      <p class="muted">Useful when you want context, not just an answer.</p>
    </div>

    <div class="resource-grid">
      {guides.map((guide) => (
        <a class="resource-link" href={guide.href}>
          <strong>{guide.title}</strong>
          <span>{guide.description}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Built on trust</p>
        <h2>Made for calmer grade conversations</h2>
      </div>
      <p class="muted">Useful for students, families, and school support teams.</p>
    </div>

    <div class="resource-grid">
      <article class="insight-card">
        <strong>Created by a math teacher</strong>
        <span>
          Grade Toolkit was created by a math teacher to help students, parents,
          tutors, and school counselors understand grades, finals, weighted
          averages, and GPA calculations more clearly.
        </span>
      </article>

      <a class="resource-link" href={guideResources.counselorResourcePage.href}>
        <strong>{guideResources.counselorResourcePage.title}</strong>
        <span>{guideResources.counselorResourcePage.description}</span>
      </a>
    </div>
  </section>

  <section class="insight-grid">
    <article class="card insight-card">
      <p class="section-eyebrow">Clear inputs</p>
      <h2>Designed for busy students</h2>
      <p>
        Each tool is built to be simple, readable, and calm under pressure, especially
        when you are checking grades between assignments, exams, and deadlines.
      </p>
    </article>

    <article class="card insight-card">
      <p class="section-eyebrow">No fluff</p>
      <h2>Answers without extra steps</h2>
      <p>
        No sign-up, no clutter, and no unnecessary screens between your numbers and
        your result.
      </p>
    </article>

    <article class="card insight-card">
      <p class="section-eyebrow">Connected guides</p>
      <h2>Learn the math behind the result</h2>
      <p>
        Each guide points back to the relevant calculator so students can read,
        test a scenario, and decide what to do next.
      </p>
    </article>
  </section>
</BaseLayout>
