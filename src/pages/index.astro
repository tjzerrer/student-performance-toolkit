---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Student Performance Toolkit"
  description="Free calculators for grades, final exams, weighted grades, and GPA."
>
  <section class="hero">
    <h1>Student Performance Toolkit</h1>
    <p>
      Free, simple tools for students who want quick answers about grades,
      finals, weighted grades, and GPA.
    </p>
  </section>

  <div class="card">
    <h2>Tools</h2>
    <ul>
      <li><a href="/grade-calculator">Grade Calculator</a></li>
      <li><a href="/final-exam-calculator">Final Exam Calculator</a></li>
      <li><a href="/weighted-grade-calculator">Weighted Grade Calculator</a></li>
    </ul>
    <p class="muted">
      More tools coming next: GPA Calculator.
    </p>
  </div>
</BaseLayout>