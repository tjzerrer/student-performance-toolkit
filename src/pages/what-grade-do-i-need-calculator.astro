---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="What Grade Do I Need Calculator (Fast & Free) | Student Performance Toolkit"
  description="Find the grade you need on your remaining coursework to reach your target grade."
>
  <section class="hero">
    <h1>What Grade Do I Need Calculator</h1>
    <p>
      Enter your current grade, your target grade, and the percentage of your
      class that is still remaining. This calculator will tell you the average
      score you need from here on out.
    </p>
  </section>

  <div class="grid">
    <section class="card">
      <h2>Enter your information</h2>

      <div class="row">
        <div>
          <label for="current-grade">Current grade (%)</label>
          <input id="current-grade" type="number" min="0" max="100" step="any" placeholder="82" />
        </div>
        <div>
          <label for="target-grade">Target grade (%)</label>
          <input id="target-grade" type="number" min="0" max="100" step="any" placeholder="90" />
        </div>
        <div>
          <label for="remaining-weight">Remaining coursework (%)</label>
          <input id="remaining-weight" type="number" min="0" max="100" step="any" placeholder="25" />
        </div>
      </div>

      <div class="actions">
        <button id="calculate" type="button" class="btn-primary">Calculate needed grade</button>
      </div>
    </section>

    <aside class="result-box">
      <div class="card">
        <h2>Your result</h2>

        <div class="result-main">
          <p class="muted">Required average</p>
          <div id="needed-result" class="big-result">--%</div>
          <p id="summary-text">Enter your values and click Calculate needed grade.</p>
        </div>

        <table class="table">
          <tbody>
            <tr>
              <th>Current grade</th>
              <td id="current-display">--</td>
            </tr>
            <tr>
              <th>Target grade</th>
              <td id="target-display">--</td>
            </tr>
            <tr>
              <th>Remaining coursework</th>
              <td id="remaining-display">--</td>
            </tr>
          </tbody>
        </table>
      </div>
    </aside>
  </div>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How this calculator works</h2>
    <p>
      This tool finds the average grade you need on the remaining portion of your
      class to reach your target overall grade.
    </p>
    <p>
      <strong>Example:</strong> If your current grade is 82%, you want a 90% overall,
      and 25% of your class is still left, this calculator tells you the average
      score you need on that remaining 25%.
    </p>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Frequently asked questions</h2>

    <div class="faq-item">
      <h3>What does remaining coursework mean?</h3>
      <p>
        It is the percent of your class grade that has not been completed yet.
        This could include a final exam, a project, quizzes, homework, or any
        other remaining assignments.
      </p>
    </div>

    <div class="faq-item">
      <h3>What if the calculator says I need over 100%?</h3>
      <p>
        That means your target grade is no longer mathematically possible unless
        your teacher offers extra credit or some other adjustment.
      </p>
    </div>

    <div class="faq-item">
      <h3>What if the calculator says I need less than 0%?</h3>
      <p>
        That means you have already secured your target grade, assuming your
        current average and remaining weight are accurate.
      </p>
    </div>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Related tools</h2>
    <ul>
      <li><a href="/grade-calculator">Grade Calculator</a></li>
      <li><a href="/final-exam-calculator">Final Exam Calculator</a></li>
      <li><a href="/weighted-grade-calculator">Weighted Grade Calculator</a></li>
      <li><a href="/gpa-calculator">GPA Calculator</a></li>
      <li><a href="/">Student Performance Toolkit home</a></li>
      <a href="/how-to-calculate-your-grade">
    How to Calculate Your Grade (Step-by-Step Guide)
    </ul>
  </section>

  <script>
    const currentInput = document.getElementById("current-grade");
    const targetInput = document.getElementById("target-grade");
    const remainingInput = document.getElementById("remaining-weight");

    const neededResult = document.getElementById("needed-result");
    const summaryText = document.getElementById("summary-text");
    const currentDisplay = document.getElementById("current-display");
    const targetDisplay = document.getElementById("target-display");
    const remainingDisplay = document.getElementById("remaining-display");

    function calculateNeededGrade() {
      const current = parseFloat(currentInput.value);
      const target = parseFloat(targetInput.value);
      const remaining = parseFloat(remainingInput.value);

      if (
        Number.isNaN(current) ||
        Number.isNaN(target) ||
        Number.isNaN(remaining) ||
        remaining <= 0 ||
        remaining > 100
      ) {
        neededResult.textContent = "--%";
        summaryText.textContent = "Please enter valid numbers. Remaining coursework must be greater than 0 and at most 100.";
        currentDisplay.textContent = "--";
        targetDisplay.textContent = "--";
        remainingDisplay.textContent = "--";
        return;
      }

      const completedWeight = 100 - remaining;
      const requiredAverage =
        (target * 100 - current * completedWeight) / remaining;

      const rounded = requiredAverage.toFixed(1);

      neededResult.textContent = `${rounded}%`;
      currentDisplay.textContent = `${current.toFixed(1).replace(/\.0$/, "")}%`;
      targetDisplay.textContent = `${target.toFixed(1).replace(/\.0$/, "")}%`;
      remainingDisplay.textContent = `${remaining.toFixed(1).replace(/\.0$/, "")}%`;

      if (requiredAverage > 100) {
        summaryText.textContent =
          `You would need a ${rounded}% average on the remaining coursework. That may not be realistic without extra credit.`;
      } else if (requiredAverage < 0) {
        summaryText.textContent =
          "You have already secured your target grade based on the values entered.";
      } else {
        summaryText.textContent =
          `You need an average of ${rounded}% on the remaining coursework to reach your target grade.`;
      }
    }

    document.getElementById("calculate")?.addEventListener("click", calculateNeededGrade);
  </script>
</BaseLayout>