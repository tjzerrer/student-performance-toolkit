---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = "https://student-performance-toolkit-6hgn.vercel.app";
const pageUrl = `${siteUrl}/what-grade-do-i-need-calculator`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What grade do I need to pass my class?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Enter your current grade, your target grade, and the remaining coursework percentage. This calculator will show the average you need."
      }
    },
    {
      "@type": "Question",
      name: "What if I need more than 100 percent?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If you need more than 100%, your target grade is not mathematically possible unless extra credit is available."
      }
    },
    {
      "@type": "Question",
      name: "What does remaining coursework mean?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It is the percentage of your class grade that has not yet been completed, such as finals, projects, or remaining assignments."
      }
    }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "What Grade Do I Need Calculator",
  url: pageUrl,
  description:
    "Find the exact grade you need on remaining coursework to reach your target grade.",
  isPartOf: {
    "@type": "WebSite",
    name: "Student Performance Toolkit",
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "What Grade Do I Need Calculator",
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title="What Grade Do I Need Calculator (Find Your Target Score Fast)"
  description="Use this free calculator to find the exact grade you need on remaining coursework to reach your goal."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <h1>What Grade Do I Need Calculator</h1>
    <p>
      Quickly find out what grade you need on your remaining coursework to reach
      your target grade.
    </p>
  </section>

  <div class="card">
    <p>
      This calculator answers one of the most common student questions:
      <strong>What grade do I need?</strong> Enter your current grade, your goal,
      and how much of your class is left to instantly see your required average.
    </p>
  </div>

  <div class="grid">
    <section class="card">
      <h2>Enter your information</h2>

      <div class="row">
        <div>
          <label>Current grade (%)</label>
          <input id="current" type="number" placeholder="82" />
        </div>
        <div>
          <label>Target grade (%)</label>
          <input id="target" type="number" placeholder="90" />
        </div>
        <div>
          <label>Remaining coursework (%)</label>
          <input id="remaining" type="number" placeholder="25" />
        </div>
      </div>

      <div class="actions">
        <button id="calculate" class="btn-primary">
          Calculate needed grade
        </button>
      </div>
    </section>

    <aside class="result-box">
      <div class="card">
        <h2>Your result</h2>

        <div class="result-main">
          <p class="muted">Required average</p>
          <div id="result" class="big-result">--%</div>
          <p id="summary">Enter values and click calculate.</p>
        </div>
      </div>
    </aside>
  </div>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How to Use This Calculator</h2>
    <ol>
      <li>Enter your current grade</li>
      <li>Enter the grade you want</li>
      <li>Enter how much of the class remains</li>
      <li>Click calculate to see what you need</li>
    </ol>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How the Formula Works</h2>
    <p>
      This calculator uses a weighted average formula to determine the grade you
      need on remaining assignments or exams to reach your target.
    </p>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Frequently Asked Questions</h2>

    <h3>What grade do I need to pass?</h3>
    <p>
      Enter your current grade, your passing goal, and remaining coursework.
      The calculator will show the required average.
    </p>

    <h3>What if I need over 100%?</h3>
    <p>
      That means your goal may not be possible without extra credit.
    </p>

    <h3>What if I already passed?</h3>
    <p>
      If the result is below 0%, you have already secured your target grade.
    </p>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Related tools</h2>
    <p>
      Try also:
      <a href="/grade-calculator">Grade Calculator</a> |
      <a href="/final-exam-calculator">Final Exam Calculator</a> |
      <a href="/weighted-grade-calculator">Weighted Grade Calculator</a> |
      <a href="/gpa-calculator">GPA Calculator</a>
    </p>
  </section>

  <script>
    const current = document.getElementById("current");
    const target = document.getElementById("target");
    const remaining = document.getElementById("remaining");

    const result = document.getElementById("result");
    const summary = document.getElementById("summary");

    document.getElementById("calculate").addEventListener("click", () => {
      const c = parseFloat(current.value);
      const t = parseFloat(target.value);
      const r = parseFloat(remaining.value);

      if (isNaN(c) || isNaN(t) || isNaN(r) || r <= 0) {
        summary.textContent = "Please enter valid values.";
        return;
      }

      const needed = (t * 100 - c * (100 - r)) / r;
      const rounded = needed.toFixed(1);

      result.textContent = `${rounded}%`;

      if (needed > 100) {
        summary.textContent =
          "You would need over 100%. That may not be realistic.";
      } else if (needed < 0) {
        summary.textContent =
          "You have already secured your target grade.";
      } else {
        summary.textContent =
          `You need an average of ${rounded}% on remaining work.`;
      }
    });
  </script>
</BaseLayout>