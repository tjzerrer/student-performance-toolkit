---
import GuideLayout from "../layouts/GuideLayout.astro";
import { guideResources, toolResources } from "../data/content";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Is a 70 a passing grade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A 70 is often considered passing in many schools, but passing policies vary by school, district, college, course, and program."
      }
    },
    {
      "@type": "Question",
      name: "Is a 70 a good grade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A 70 is usually considered a low passing grade. It means you passed, but it may still leave little room for mistakes and may not support stronger GPA goals."
      }
    },
    {
      "@type": "Question",
      name: "Can I still raise a 70 before the end of the class?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. A 70 can often be improved by raising scores on remaining assignments, tests, projects, or the final exam."
      }
    }
  ]
};

const relatedItems = [
  guideResources.whatGradeDoINeedToPass,
  toolResources.gradeCalculator,
  toolResources.whatGradeDoINeedCalculator,
  toolResources.finalExamCalculator,
];
---

<GuideLayout
  title="Is a 70 a Passing Grade?"
  description="Learn what a 70 usually means, when it counts as passing, and which calculators can help you plan your next step."
  slug="/is-a-70-a-passing-grade"
  heroTitle="Is a 70 a Passing Grade?"
  heroText="A 70 is often considered passing, but the real answer depends on your school, your course, and what you need that grade to do for you."
  faqSchema={faqSchema}
  relatedItems={relatedItems}
>
  <div class="guide-body">
    <section class="card">
      <p>
        <strong>Short answer:</strong> a 70 is often considered passing in many
        schools, but passing policies vary by school, district, college, course,
        and program. Always check your teacher's syllabus, school handbook, or
        counselor guidance.
      </p>
    </section>

    <section class="card">
      <h2>Common Grade Meaning Table</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Grade range</th>
            <th>Common meaning</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>90-100</td><td>A / excellent</td></tr>
          <tr><td>80-89</td><td>B / above average</td></tr>
          <tr><td>70-79</td><td>C / often considered passing</td></tr>
          <tr><td>60-69</td><td>D / sometimes passing, depending on school policy</td></tr>
          <tr><td>Below 60</td><td>Usually failing</td></tr>
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>What a 70 Usually Means</h2>
      <p>
        A 70 usually means you are passing, but with a small margin for error.
        One low test score or missed assignment can matter a lot when your grade is
        near the lower end of the passing range.
      </p>
      <ul>
        <li>You may be passing the class right now</li>
        <li>You may still need improvement for eligibility or GPA goals</li>
        <li>You may need to protect that grade if a large final exam is still ahead</li>
      </ul>
    </section>

    <section class="card">
      <h2>What to Do Next</h2>
      <ul>
        <li>Check your current percentage with the <a href="/grade-calculator/">Grade Calculator</a>.</li>
        <li>Estimate your target with the <a href="/what-grade-do-i-need-calculator/">What Grade Do I Need Calculator</a>.</li>
        <li>If a big exam is left, try the <a href="/final-exam-calculator/">Final Exam Calculator</a>.</li>
      </ul>
    </section>

    <section class="card">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>Is a 70 a passing grade in high school?</h3>
        <p>Often yes, but schools and districts do not all use the same cutoffs.</p>
      </div>
      <div class="faq-item">
        <h3>Is a 70 enough for college admissions?</h3>
        <p>A passing grade is not always the same as a competitive grade. College expectations depend on the school, the course rigor, and your overall GPA.</p>
      </div>
      <div class="faq-item">
        <h3>Can a final exam move a 70 up quickly?</h3>
        <p>Sometimes. The answer depends on how much the final exam counts and how much room you still have to improve.</p>
      </div>
    </section>
  </div>
</GuideLayout>
