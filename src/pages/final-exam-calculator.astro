---
import ToolLayout from "../layouts/ToolLayout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I calculate what I need on my final exam?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "You need your current grade, your desired final grade, and the weight of the final exam. This calculator does that math for you automatically."
      }
    },
    {
      "@type": "Question",
      name: "What if I need more than 100% on my final?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If the calculator says you need more than 100%, your target grade may not be possible unless extra credit or another adjustment is available."
      }
    },
    {
      "@type": "Question",
      name: "What if the calculator says I need less than 0%?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "That means you have already secured your desired grade based on the numbers you entered."
      }
    }
  ]
};
---

<ToolLayout
  title="Final Exam Calculator (What Do I Need on My Final?)"
  description="Use this free final exam calculator to find the exact score you need on your final to reach your target grade."
  slug="/final-exam-calculator"
  heroTitle="Final Exam Calculator"
  heroText="Find out exactly what you need on your final exam to reach your target grade. Enter your current grade, desired grade, and final exam weight to get an instant answer."
  faqSchema={faqSchema}
>
  <div class="card">
    <p>
      This final exam calculator helps students quickly answer one of the most
      common questions in school: <strong>What do I need on my final?</strong>
      If you know your current grade and how much your final exam counts, this
      tool will show the score you need right away.
    </p>
  </div>

  <div class="grid">
    <section class="card">
      <h2>Enter your information</h2>

      <div class="row">
        <div>
          <label for="current">Current grade (%)</label>
          <input id="current" type="number" min="0" max="100" step="any" placeholder="85" />
        </div>
        <div>
          <label for="desired">Desired grade (%)</label>
          <input id="desired" type="number" min="0" max="100" step="any" placeholder="90" />
        </div>
      </div>

      <div class="row">
        <div>
          <label for="weight">Final exam weight (%)</label>
          <input id="weight" type="number" min="0" max="100" step="any" placeholder="20" />
        </div>
      </div>

      <div class="actions">
        <button id="calculate" class="btn-primary">
          Calculate required score
        </button>
      </div>
    </section>

    <aside class="result-box">
      <div class="card">
        <h2>Your result</h2>

        <div class="result-main">
          <p class="muted">Required score on final</p>
          <div id="result" class="big-result">--%</div>
          <p id="summary">
            Enter your values and click calculate.
          </p>
        </div>
      </div>
    </aside>
  </div>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How to Use the Final Exam Calculator</h2>
    <ol>
      <li>Enter your current class grade</li>
      <li>Enter the overall grade you want</li>
      <li>Enter how much your final exam counts</li>
      <li>Click calculate to see the score you need</li>
    </ol>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How the Formula Works</h2>
    <p>
      This calculator uses a weighted average formula to determine the score you
      need on the remaining final exam portion of your class.
    </p>
    <p>
      <strong>Example:</strong> If your current grade is 85%, your final exam is
      worth 20%, and you want a 90% overall, the calculator tells you the exact
      score needed on that final.
    </p>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Frequently Asked Questions</h2>

    <div class="faq-item">
      <h3>How do I calculate what I need on my final exam?</h3>
      <p>
        You need your current grade, your target grade, and the weight of the
        final exam. This calculator combines those values and gives you the
        exact score you need.
      </p>
    </div>

    <div class="faq-item">
      <h3>What if I need more than 100% on my final?</h3>
      <p>
        That means your goal may not be mathematically possible unless extra
        credit or another grade adjustment is available.
      </p>
    </div>

    <div class="faq-item">
      <h3>What if the result is below 0%?</h3>
      <p>
        That means you have already secured your target grade based on the
        values you entered.
      </p>
    </div>
  </section>

  <script>
    const currentInput = document.getElementById("current");
    const desiredInput = document.getElementById("desired");
    const weightInput = document.getElementById("weight");
    const resultDiv = document.getElementById("result");
    const summary = document.getElementById("summary");

    document.getElementById("calculate").addEventListener("click", () => {
      const current = parseFloat(currentInput.value);
      const desired = parseFloat(desiredInput.value);
      const weight = parseFloat(weightInput.value);

      if (
        isNaN(current) ||
        isNaN(desired) ||
        isNaN(weight) ||
        weight <= 0 ||
        weight > 100
      ) {
        resultDiv.textContent = "--%";
        summary.textContent =
          "Please enter valid numbers. Final exam weight must be greater than 0 and at most 100.";
        return;
      }

      const weightDecimal = weight / 100;
      const required =
        (desired - current * (1 - weightDecimal)) / weightDecimal;

      const rounded = required.toFixed(1);
      resultDiv.textContent = `${rounded}%`;

      if (required > 100) {
        summary.textContent =
          `You would need ${rounded}% on your final. That may not be realistic without extra credit.`;
      } else if (required < 0) {
        summary.textContent =
          "You have already secured your desired grade based on the numbers entered.";
      } else {
        summary.textContent =
          `You need ${rounded}% on your final to reach your target grade.`;
      }
    });
  </script>
</ToolLayout>