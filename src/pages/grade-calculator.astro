---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Grade Calculator (Easy, Accurate, Free)"
  description="Use this free grade calculator to find your current grade percentage and letter grade from assignment scores."
>
  <section class="hero">
    <h1>Grade Calculator</h1>
    <p>
      Enter your assignment scores below to calculate your current percentage
      and letter grade. This tool is fast, simple, and built for students who
      want an immediate answer.
    </p>
  </section>

  <div class="grid">
    <section class="card">
      <h2>Enter your scores</h2>

      <div id="assignment-list">
        <div class="row assignment-row">
          <div>
            <label for="earned-1">Points earned</label>
            <input id="earned-1" class="earned" type="number" min="0" step="any" placeholder="85" />
          </div>
          <div>
            <label for="possible-1">Points possible</label>
            <input id="possible-1" class="possible" type="number" min="0" step="any" placeholder="100" />
          </div>
          <div style="align-self:end;">
            <button type="button" class="btn-danger remove-row">Remove</button>
          </div>
        </div>

        <div class="row assignment-row">
          <div>
            <label for="earned-2">Points earned</label>
            <input id="earned-2" class="earned" type="number" min="0" step="any" placeholder="18" />
          </div>
          <div>
            <label for="possible-2">Points possible</label>
            <input id="possible-2" class="possible" type="number" min="0" step="any" placeholder="20" />
          </div>
          <div style="align-self:end;">
            <button type="button" class="btn-danger remove-row">Remove</button>
          </div>
        </div>

        <div class="row assignment-row">
          <div>
            <label for="earned-3">Points earned</label>
            <input id="earned-3" class="earned" type="number" min="0" step="any" placeholder="42" />
          </div>
          <div>
            <label for="possible-3">Points possible</label>
            <input id="possible-3" class="possible" type="number" min="0" step="any" placeholder="50" />
          </div>
          <div style="align-self:end;">
            <button type="button" class="btn-danger remove-row">Remove</button>
          </div>
        </div>
      </div>

      <div class="actions">
        <button id="add-row" type="button" class="btn-secondary">Add assignment</button>
        <button id="calculate" type="button" class="btn-primary">Calculate grade</button>
      </div>
    </section>

    <aside class="result-box">
      <div class="card">
        <h2>Your result</h2>

        <div class="result-main">
          <p class="muted">Current grade</p>
          <div id="percent-result" class="big-result">--%</div>
          <p id="letter-result"><strong>Letter grade:</strong> --</p>
          <p id="summary-text">Enter your scores and click Calculate grade.</p>
        </div>

        <table class="table">
          <tbody>
            <tr>
              <th>Total points earned</th>
              <td id="total-earned">--</td>
            </tr>
            <tr>
              <th>Total points possible</th>
              <td id="total-possible">--</td>
            </tr>
          </tbody>
        </table>
      </div>
    </aside>
  </div>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How this grade calculator works</h2>
    <p>
      This calculator adds all of your earned points and divides by the total
      points possible. It then converts that percentage into a letter grade.
    </p>
    <p>
      <strong>Example:</strong> If you earned 145 points out of 170 possible,
      your grade is 145 ÷ 170 = 0.8529, or <strong>85.3%</strong>.
    </p>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Frequently asked questions</h2>

    <div class="faq-item">
      <h3>Can I use this for multiple assignments?</h3>
      <p>
        Yes. Add as many assignments, quizzes, tests, or projects as you need.
      </p>
    </div>

    <div class="faq-item">
      <h3>Does this calculator use weighted categories?</h3>
      <p>
        No. This page uses total points. A weighted grade calculator should be a
        separate tool, and that should be your next build.
      </p>
    </div>

    <div class="faq-item">
      <h3>What grading scale does this use?</h3>
      <p>
        This version uses a simple default scale: A = 90–100, B = 80–89,
        C = 70–79, D = 60–69, F = below 60.
      </p>
    </div>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Related tools</h2>
    <ul>
      <li><a href="/final-exam-calculator">Final Exam Calculator</a></li>
      <li><a href="/weighted-grade-calculator">Weighted Grade Calculator</a></li>
       <li><a href="/gpa-calculator">GPA Calculator</a></li>
       <li><a href="/what-grade-do-i-need-calculator">What Grade Do I Need Calculator</a></li>
       <li><a href="/">Student Performance Toolkit home</a></li>
    </ul>
  </section>

  <script>
    let rowCount = 3;

    const assignmentList = document.getElementById("assignment-list");
    const addRowButton = document.getElementById("add-row");
    const calculateButton = document.getElementById("calculate");

    const percentResult = document.getElementById("percent-result");
    const letterResult = document.getElementById("letter-result");
    const summaryText = document.getElementById("summary-text");
    const totalEarnedCell = document.getElementById("total-earned");
    const totalPossibleCell = document.getElementById("total-possible");

    function getLetterGrade(percent) {
      if (percent >= 90) return "A";
      if (percent >= 80) return "B";
      if (percent >= 70) return "C";
      if (percent >= 60) return "D";
      return "F";
    }

    function addRow() {
      rowCount += 1;

      const row = document.createElement("div");
      row.className = "row assignment-row";

      row.innerHTML = `
        <div>
          <label for="earned-${rowCount}">Points earned</label>
          <input id="earned-${rowCount}" class="earned" type="number" min="0" step="any" placeholder="0" />
        </div>
        <div>
          <label for="possible-${rowCount}">Points possible</label>
          <input id="possible-${rowCount}" class="possible" type="number" min="0" step="any" placeholder="0" />
        </div>
        <div style="align-self:end;">
          <button type="button" class="btn-danger remove-row">Remove</button>
        </div>
      `;

      assignmentList.appendChild(row);
    }

    function calculateGrade() {
      const earnedInputs = document.querySelectorAll(".earned");
      const possibleInputs = document.querySelectorAll(".possible");

      let totalEarned = 0;
      let totalPossible = 0;

      for (let i = 0; i < earnedInputs.length; i++) {
        const earned = parseFloat(earnedInputs[i].value);
        const possible = parseFloat(possibleInputs[i].value);

        if (!Number.isNaN(earned) && !Number.isNaN(possible) && possible > 0) {
          totalEarned += earned;
          totalPossible += possible;
        }
      }

      if (totalPossible === 0) {
        percentResult.textContent = "--%";
        letterResult.innerHTML = "<strong>Letter grade:</strong> --";
        summaryText.textContent = "Please enter at least one valid assignment.";
        totalEarnedCell.textContent = "--";
        totalPossibleCell.textContent = "--";
        return;
      }

      const percent = (totalEarned / totalPossible) * 100;
      const roundedPercent = percent.toFixed(1);
      const letter = getLetterGrade(percent);

      percentResult.textContent = `${roundedPercent}%`;
      letterResult.innerHTML = `<strong>Letter grade:</strong> ${letter}`;
      summaryText.textContent = `Your current grade is ${roundedPercent}% (${letter}).`;
      totalEarnedCell.textContent = totalEarned.toFixed(2).replace(/\.00$/, "");
      totalPossibleCell.textContent = totalPossible.toFixed(2).replace(/\.00$/, "");
    }

    addRowButton?.addEventListener("click", addRow);
    calculateButton?.addEventListener("click", calculateGrade);

    assignmentList?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      if (target.classList.contains("remove-row")) {
        const rows = document.querySelectorAll(".assignment-row");
        if (rows.length <= 1) return;

        const row = target.closest(".assignment-row");
        row?.remove();
      }
    });
  </script>
</BaseLayout>