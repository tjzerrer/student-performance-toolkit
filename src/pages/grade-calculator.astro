---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = "https://student-performance-toolkit-6hgn.vercel.app";
const pageUrl = `${siteUrl}/grade-calculator`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I calculate my grade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Add all your earned points together and divide by the total possible points. This calculator does that automatically."
      }
    },
    {
      "@type": "Question",
      name: "What is a good grade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A good grade is usually 80% or higher, depending on your goals and school standards."
      }
    },
    {
      "@type": "Question",
      name: "Can I calculate weighted grades here?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "This page is for simple total-point grade calculation. For weighted categories, use the weighted grade calculator."
      }
    }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Grade Calculator",
  url: pageUrl,
  description:
    "Calculate your grade instantly. Enter assignments and scores to find your average in seconds.",
  isPartOf: {
    "@type": "WebSite",
    name: "Student Performance Toolkit",
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Grade Calculator",
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title="Grade Calculator (Quick & Easy Average Calculator for Students)"
  description="Calculate your grade instantly. Enter assignments and scores to find your average in seconds."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <h1>Grade Calculator</h1>
    <p>
      Quickly calculate your grade using this simple and accurate grade calculator.
      Enter your assignment scores to instantly find your average.
    </p>
  </section>

  <div class="card">
    <p>
      This grade calculator helps students calculate their average grade quickly and accurately.
      Whether you're tracking homework, quizzes, or tests, this tool gives you an instant result.
    </p>
  </div>

  <div class="grid">
    <section class="card">
      <h2>Enter your scores</h2>

      <div id="assignment-list">
        <div class="row assignment-row">
          <div>
            <label>Points earned</label>
            <input class="earned" type="number" min="0" step="any" placeholder="90" />
          </div>
          <div>
            <label>Points possible</label>
            <input class="possible" type="number" min="0" step="any" placeholder="100" />
          </div>
          <div style="align-self:end;">
            <button type="button" class="btn-danger remove-row">Remove</button>
          </div>
        </div>

        <div class="row assignment-row">
          <div>
            <label>Points earned</label>
            <input class="earned" type="number" min="0" step="any" placeholder="85" />
          </div>
          <div>
            <label>Points possible</label>
            <input class="possible" type="number" min="0" step="any" placeholder="100" />
          </div>
          <div style="align-self:end;">
            <button type="button" class="btn-danger remove-row">Remove</button>
          </div>
        </div>
      </div>

      <div class="actions">
        <button id="add-assignment" type="button" class="btn-secondary">Add assignment</button>
        <button id="calculate" type="button" class="btn-primary">Calculate grade</button>
      </div>
    </section>

    <aside class="result-box">
      <div class="card">
        <h2>Your result</h2>
        <div class="result-main">
          <p class="muted">Average grade</p>
          <div id="result" class="big-result">--%</div>
          <p id="summary">Enter your values and click calculate.</p>
        </div>
      </div>
    </aside>
  </div>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>How to Use the Grade Calculator</h2>
    <ol>
      <li>Enter each assignment score</li>
      <li>Enter the total possible points</li>
      <li>Click calculate</li>
      <li>View your current grade instantly</li>
    </ol>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Frequently Asked Questions</h2>

    <div class="faq-item">
      <h3>How do I calculate my grade?</h3>
      <p>
        Add all your assignment scores together and divide by the total possible points.
        This calculator does it automatically for you.
      </p>
    </div>

    <div class="faq-item">
      <h3>What is a good grade?</h3>
      <p>
        A good grade is typically 80% or higher, depending on your goals and school standards.
      </p>
    </div>

    <div class="faq-item">
      <h3>Can I calculate weighted grades?</h3>
      <p>
        Yes, use our <a href="/weighted-grade-calculator">Weighted Grade Calculator</a>.
      </p>
    </div>
  </section>

  <section class="card" style="margin-top: 1.25rem;">
    <h2>Related tools</h2>
    <p>
      Try also:
      <a href="/final-exam-calculator">Final Exam Calculator</a> |
      <a href="/weighted-grade-calculator">Weighted Grade Calculator</a> |
      <a href="/gpa-calculator">GPA Calculator</a> |
      <a href="/what-grade-do-i-need-calculator">What Grade Do I Need Calculator</a>
    </p>
  </section>

  <script>
    const assignmentList = document.getElementById("assignment-list");
    const addBtn = document.getElementById("add-assignment");
    const calcBtn = document.getElementById("calculate");
    const resultDiv = document.getElementById("result");
    const summary = document.getElementById("summary");

    addBtn?.addEventListener("click", () => {
      const row = document.createElement("div");
      row.className = "row assignment-row";

      row.innerHTML = `
        <div>
          <label>Points earned</label>
          <input class="earned" type="number" min="0" step="any" placeholder="90" />
        </div>
        <div>
          <label>Points possible</label>
          <input class="possible" type="number" min="0" step="any" placeholder="100" />
        </div>
        <div style="align-self:end;">
          <button type="button" class="btn-danger remove-row">Remove</button>
        </div>
      `;

      assignmentList?.appendChild(row);
    });

    assignmentList?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      if (target.classList.contains("remove-row")) {
        const rows = document.querySelectorAll(".assignment-row");
        if (rows.length <= 1) return;

        const row = target.closest(".assignment-row");
        row?.remove();
      }
    });

    calcBtn?.addEventListener("click", () => {
      const earnedInputs = document.querySelectorAll(".earned");
      const possibleInputs = document.querySelectorAll(".possible");

      let totalEarned = 0;
      let totalPossible = 0;

      for (let i = 0; i < earnedInputs.length; i++) {
        const earned = parseFloat(earnedInputs[i].value);
        const possible = parseFloat(possibleInputs[i].value);

        if (!Number.isNaN(earned) && !Number.isNaN(possible) && possible > 0) {
          totalEarned += earned;
          totalPossible += possible;
        }
      }

      if (totalPossible === 0) {
        resultDiv.textContent = "--%";
        summary.textContent = "Please enter valid numbers.";
        return;
      }

      const percent = (totalEarned / totalPossible) * 100;
      const rounded = percent.toFixed(1);

      resultDiv.textContent = `${rounded}%`;
      summary.textContent = `Your current grade is ${rounded}%.`;
    });
  </script>
</BaseLayout>