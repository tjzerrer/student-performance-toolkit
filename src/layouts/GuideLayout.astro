---
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import ResourceLinks from "../components/ResourceLinks.astro";
import { site } from "../data/site";
import type { ResourceLink } from "../data/content";

interface Props {
  title: string;
  description: string;
  slug: string;
  heroTitle?: string;
  heroText?: string;
  faqSchema?: Record<string, any> | null;
  relatedItems?: ResourceLink[];
  relatedTitle?: string;
  relatedIntro?: string;
}

const {
  title,
  description,
  slug,
  heroTitle = title,
  heroText = description,
  faqSchema = null,
  relatedItems = [],
  relatedTitle = "Related Tools and Guides",
  relatedIntro = "Use the next calculator or guide that fits the grade question you are working through."
} = Astro.props;

const siteUrl = site.url;
const normalizedSlug = `${slug.replace(/\/$/, "")}/`;
const pageUrl = `${siteUrl}${normalizedSlug}`;
const socialImage = "/social-preview.png";
const socialImageAlt = `${heroTitle} social preview card`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  mainEntityOfPage: pageUrl,
  description,
  author: {
    "@type": "Organization",
    name: site.name
  },
  publisher: {
    "@type": "Organization",
    name: site.name,
    url: siteUrl
  },
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Guides",
      item: `${siteUrl}/guides/`
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  socialImage={socialImage}
  socialImageAlt={socialImageAlt}
>
  <Fragment slot="head">
    <JsonLd data={articleSchema} />
    <JsonLd data={breadcrumbSchema} />
    {faqSchema && <JsonLd data={faqSchema} />}
  </Fragment>

  <section class="hero-card">
    <div class="hero">
      <p class="hero-eyebrow">Student guide</p>
      <h1>{heroTitle}</h1>
      <p class="hero-copy">{heroText}</p>
    </div>
  </section>

  <slot />
  {relatedItems.length > 0 && (
    <ResourceLinks
      eyebrow="Helpful next steps"
      title={relatedTitle}
      intro={relatedIntro}
      items={relatedItems}
    />
  )}
</BaseLayout>
