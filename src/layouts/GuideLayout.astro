---
import BaseLayout from "./BaseLayout.astro";
import RelatedTools from "../components/RelatedTools.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  slug: string;
  heroTitle?: string;
  heroText?: string;
  faqSchema?: Record<string, any> | null;
}

const {
  title,
  description,
  slug,
  heroTitle = title,
  heroText = description,
  faqSchema = null
} = Astro.props;

const siteUrl = site.url;
const pageUrl = `${siteUrl}${slug}`;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url: pageUrl,
  description,
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: title,
      item: pageUrl
    }
  ]
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <section class="hero">
    <h1>{heroTitle}</h1>
    <p>{heroText}</p>
  </section>

  <slot />

  <RelatedTools />
  <RelatedGuides current={slug} />
</BaseLayout>