---
import BaseLayout from "./BaseLayout.astro";
import RelatedTools from "../components/RelatedTools.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import JsonLd from "../components/JsonLd.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  slug: string;
  heroTitle?: string;
  heroText?: string;
  faqSchema?: Record<string, any> | null;
}

const {
  title,
  description,
  slug,
  heroTitle = title,
  heroText = description,
  faqSchema = null
} = Astro.props;

const siteUrl = site.url;
const pageUrl = `${siteUrl}${slug}`;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url: pageUrl,
  description,
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: title,
      item: pageUrl
    }
  ]
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <JsonLd data={webPageSchema} />
    <JsonLd data={breadcrumbSchema} />
    {faqSchema && <JsonLd data={faqSchema} />}
  </Fragment>

  <section class="hero">
    <h1>{heroTitle}</h1>
    <p>{heroText}</p>
  </section>

  <div class="print-save-actions" aria-label="Print and save options">
    <button id="print-calculator" type="button" class="btn-secondary icon-button">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M7 8V3h10v5M7 17H5a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2M7 14h10v7H7zM17 12h.01" />
      </svg>
      Print
    </button>
    <button id="save-pdf-calculator" type="button" class="btn-secondary icon-button">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M14 3v4a2 2 0 0 0 2 2h4M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9zM8 15h8M8 18h5" />
      </svg>
      Save PDF
    </button>
  </div>

  <slot />

  <div class="related-links">
    <RelatedTools current={slug} />
    <RelatedGuides />
  </div>

  <script>
    const printButton = document.getElementById("print-calculator");
    const savePdfButton = document.getElementById("save-pdf-calculator");

    function openPrintDialog(intent) {
      document.body.dataset.printIntent = intent;
      window.print();
    }

    printButton?.addEventListener("click", () => openPrintDialog("print"));
    savePdfButton?.addEventListener("click", () => openPrintDialog("pdf"));
    window.addEventListener("afterprint", () => {
      delete document.body.dataset.printIntent;
    });
  </script>
</BaseLayout>
