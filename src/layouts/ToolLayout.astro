---
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import ResourceLinks from "../components/ResourceLinks.astro";
import { site } from "../data/site";
import type { ResourceLink } from "../data/content";

interface Props {
  title: string;
  description: string;
  slug: string;
  heroTitle?: string;
  heroText?: string;
  faqSchema?: Record<string, any> | null;
  relatedItems?: ResourceLink[];
  relatedTitle?: string;
  relatedIntro?: string;
}

const {
  title,
  description,
  slug,
  heroTitle = title,
  heroText = description,
  faqSchema = null,
  relatedItems = [],
  relatedTitle = "Related Tools and Guides",
  relatedIntro = "Jump to the next calculator or guide students usually need after this result."
} = Astro.props;

const siteUrl = site.url;
const normalizedSlug = `${slug.replace(/\/$/, "")}/`;
const pageUrl = `${siteUrl}${normalizedSlug}`;
const socialSlug = normalizedSlug.replace(/^\/|\/$/g, "");
const socialImage = `/social/tools/${socialSlug}.png`;
const socialImageAlt = `${heroTitle} social preview card`;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url: pageUrl,
  description,
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: siteUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: title,
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="website"
  socialImage={socialImage}
  socialImageAlt={socialImageAlt}
>
  <Fragment slot="head">
    <JsonLd data={webPageSchema} />
    <JsonLd data={breadcrumbSchema} />
    {faqSchema && <JsonLd data={faqSchema} />}
  </Fragment>

  <section class="hero-card">
    <div class="hero">
      <p class="hero-eyebrow">Student calculator</p>
      <h1>{heroTitle}</h1>
      <p class="hero-copy">{heroText}</p>
      <p class="hero-note">
        Use the calculator below, then print or save the result once you have the answer you need.
      </p>
    </div>
  </section>

  <slot />

  <div
    class="print-save-actions"
    aria-label="Print and save options"
    style="display: none; gap: 0.45rem; margin-top: 0.45rem; flex-wrap: wrap;"
    hidden
  >
    <button id="print-calculator" type="button" class="btn-secondary icon-button">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 8V3h10v5M7 17H5a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2M7 14h10v7H7zM17 12h.01" />
      </svg>
      Print or Save as PDF
    </button>
  </div>

  {relatedItems.length > 0 && (
    <ResourceLinks
      eyebrow="Keep going"
      title={relatedTitle}
      intro={relatedIntro}
      items={relatedItems}
    />
  )}

  <script>
    const printSaveActions = document.querySelector(".print-save-actions");
    const printButton = document.getElementById("print-calculator");
    const calculateButton = document.getElementById("calculate");
    const calculatorActions = calculateButton?.closest(".actions");
    const calculatorCard = calculateButton?.closest(".card");

    if (calculatorActions && printSaveActions) {
      calculatorActions.appendChild(printSaveActions);
    }

    function hasCalculationResult() {
      return Array.from(document.querySelectorAll(".big-result")).some((result) => {
        const value = result.textContent?.trim() || "";
        return value !== "" && !value.startsWith("--");
      });
    }

    function updatePrintSaveVisibility() {
      if (!printSaveActions) return;
      const hasResult = hasCalculationResult();
      printSaveActions.hidden = !hasResult;
      printSaveActions.style.display = hasResult ? "flex" : "none";
    }

    function hidePrintSaveActions() {
      if (!printSaveActions) return;
      printSaveActions.hidden = true;
      printSaveActions.style.display = "none";
    }

    function openPrintDialog() {
      window.print();
    }

    calculateButton?.addEventListener("click", () => {
      window.setTimeout(updatePrintSaveVisibility, 0);
    });
    calculatorCard?.addEventListener("input", hidePrintSaveActions);
    calculatorCard?.addEventListener("change", hidePrintSaveActions);
    calculatorCard?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const button = target.closest("button");
      if (!button || button === calculateButton || button.closest(".print-save-actions")) return;

      hidePrintSaveActions();
    });
    printButton?.addEventListener("click", openPrintDialog);
  </script>
</BaseLayout>
