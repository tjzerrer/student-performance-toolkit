---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";
import { site } from "../data/site";

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  socialImage?: string;
  socialImageAlt?: string;
}

const {
  title,
  description = site.description,
  ogType = "website",
  socialImage = "/social-preview.png",
  socialImageAlt = `${title} social preview`,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const resolvedSocialImage = new URL(socialImage, site.url).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta
      name="google-site-verification"
      content="1dNa9CgRh9xz2zgKDLdX_eu8KMNQMwiVyrE0EHTv72o"
    />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={resolvedSocialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedSocialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <slot name="head" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <img
            class="brand-mark"
            src="/brand-mark.svg"
            alt=""
            aria-hidden="true"
            width="48"
            height="48"
          />
          <span class="brand-copy">
            <strong>Grade Toolkit</strong>
            <small>Student calculators and grade guides</small>
          </span>
        </a>

        <nav class="top-nav" aria-label="Primary">
          <a href="/grade-calculator/">Grade Calculator</a>
          <a href="/gpa-calculator/">GPA Calculator</a>
          <a href="/final-exam-calculator/">Final Exam Calculator</a>
          <a href="/guides/">Guides</a>
        </nav>
      </header>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__content">
          <div>
            <strong>Grade Toolkit</strong>
            <p class="footer-note">
              Grade Toolkit was created by a math teacher to help students,
              parents, tutors, and school counselors understand grades, finals,
              weighted averages, and GPA calculations more clearly.
            </p>
          </div>

          <div class="footer-links">
            <a href="/grade-calculator/">Tools</a>
            <a href="/guides/">Guides</a>
            <a href="/guides/how-to-calculate-gpa-with-credits/">GPA Tips</a>
            <a href="/grade-calculators-for-students-parents-counselors/">Counselor Resources</a>
            <a href="/contact/">Contact</a>
          </div>
        </div>
      </footer>
    </div>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
